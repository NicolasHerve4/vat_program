# =============================================================================
# Business Central - Connexion OAuth2 (Entra ID / Azure AD)
# Copie ce fichier en ".env" et renseigne tes valeurs.
# NE COMMITE JAMAIS le .env reel dans Git (voir .gitignore).
# =============================================================================

# --- Authentification Entra ID (app registration, client credentials) -------
BC_TENANT_ID=00000000-0000-0000-0000-000000000000
BC_CLIENT_ID=00000000-0000-0000-0000-000000000000
BC_CLIENT_SECRET=ton_secret_client_ici

# --- Environnement Business Central ------------------------------------------
# Nom de l'environnement BC (ex: Production, Sandbox)
BC_ENVIRONMENT=Production
# Nom EXACT de la societe tel qu'affiche dans BC (respecte espaces/accents)
BC_COMPANY_NAME=Ma Societe SAS

# --- Scope OAuth2 (laisser par defaut pour BC SaaS) --------------------------
BC_SCOPE=https://api.businesscentral.dynamics.com/.default
